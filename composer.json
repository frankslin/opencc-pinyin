{
    "name": "frankslin/opencc-pinyin",
    "description": "Packed Hanyu Pinyin lookup data (zdic.net via mozillazg/pinyin-data) with an O(1) codepoint-addressed PHP loader; tone-marked by default, toneless on demand.",
    "type": "library",
    "license": "MIT",
    "keywords": ["pinyin", "chinese", "opencc", "cjk"],
    "require": {
        "php": ">=8.2",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "OpenccPinyin\\": "php/src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OpenccPinyin\\Tests\\": "php/tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:data": "php php/verify_packed_dict.php"
    }
}
